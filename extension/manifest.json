{
  "manifest_version": 3,
  "name": "Vibe Typing — Smart Translator",
  "version": "0.1.0",
  "description": "Highlight any text to get instant translation suggestions with a sleek dropdown.",
  "permissions": ["activeTab", "storage"],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Vibe Typing"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
