{
  "manifest_version": 3,
  "name": "Vibe Typing — Smart Translator",
  "version": "0.3.0",
  "description": "AI-powered translation and vocabulary suggestions while you type.",
  "permissions": [
    "storage",
    "tabs",
    "activeTab"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "content_scripts": [
    {
      "js": [
        "assets/index.ts-loader-CKsMmFiw.js"
      ],
      "matches": [
        "<all_urls>"
      ],
      "run_at": "document_idle",
      "css": [
        "assets/index-BTNoNaTv.css"
      ]
    }
  ],
  "background": {
    "service_worker": "service-worker-loader.js",
    "type": "module"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Vibe Typing",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "options_page": "options.html",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "web_accessible_resources": [
    {
      "matches": [
        "<all_urls>"
      ],
      "resources": [
        "assets/ProtocolClient-CGKQZBsb.js",
        "assets/ProtocolClient-CGKQZBsb.js.map",
        "assets/index.ts-FK5UeXkS.js",
        "assets/index.ts-FK5UeXkS.js.map"
      ],
      "use_dynamic_url": false
    }
  ]
}
